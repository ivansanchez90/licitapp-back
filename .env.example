# Copiá este archivo a .env y ajustá los valores. .env está gitignored.

# PostgreSQL (usado por docker-compose)
POSTGRES_USER=licitapp
POSTGRES_PASSWORD=licitapp_dev
POSTGRES_DB=licitapp

# Firebase (sólo se usa el Project ID para verificar los ID Tokens)
FIREBASE_PROJECT_ID=licitapp-e1841

# Connection string para la API corriendo fuera de Docker (dotnet run):
# ConnectionStrings__Default=Host=localhost;Port=5432;Database=licitapp;Username=licitapp;Password=licitapp_dev
